{
	"name": "@wiscaksono/sveltekit-route-intercept",
	"version": "0.1.1",
	"type": "module",
	"license": "MIT",
	"description": "Type-safe route interception for SvelteKit",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/wiscaksono/sveltekit-route-intercept.git"
	},
	"homepage": "https://github.com/wiscaksono/sveltekit-route-intercept#readme",
	"bugs": {
		"url": "https://github.com/wiscaksono/sveltekit-route-intercept/issues"
	},
	"keywords": [
		"svelte",
		"sveltekit",
		"routing",
		"modal",
		"intercept"
	],
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./vite": {
			"types": "./dist/vite.d.ts",
			"import": "./dist/vite.js"
		}
	},
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.0.0",
		"svelte": "^5.0.0"
	},
	"scripts": {
		"build": "tsup src/index.ts src/vite.ts --format esm --dts --clean --external '$app/navigation' --external '$app/state' --external '$app/paths'",
		"prepack": "pnpm run build",
		"check": "tsc -p tsconfig.json --noEmit",
		"lint": "tsc -p tsconfig.json --noEmit",
		"test": "vitest run",
		"test:types": "tsc -p tsconfig.type-tests.json --noEmit"
	},
	"devDependencies": {
		"@types/node": "^24.7.2",
		"tsup": "^8.5.0",
		"typescript": "^5.9.3",
		"svelte": "^5.39.0",
		"vite": "^7.1.12",
		"vitest": "^3.2.4"
	}
}
